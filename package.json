{
  "name": "homebridge-mspa",
  "version": "1.0.0",
  "description": "Homebridge plugin for MSpa hot tubs",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "test": "jest",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["homebridge-plugin", "mspa", "hot-tub", "spa"],
  "engines": {
    "node": ">=18.0.0",
    "homebridge": ">=1.6.0"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "md5": "^2.3.0"
  },
  "devDependencies": {
    "@types/md5": "^2.3.5",
    "@types/node": "^20.0.0",
    "homebridge": "^1.8.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0",
    "@types/jest": "^29.0.0"
  },
  "peerDependencies": {
    "homebridge": ">=1.6.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.ts"],
    "testPathIgnorePatterns": ["/node_modules/", "/tests/\\._"]
  }
}
